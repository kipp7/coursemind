# CourseMind local development configuration.
# Never commit real API keys or school/private course data.

# Defaults to "sqlite" when unset.
# Supported values today: sqlite, in-memory.
# SQLite stores local MVP state in data/coursemind.sqlite by default.
COURSEMIND_STORAGE=sqlite
# COURSEMIND_SQLITE_PATH=E:/coursemind-data/coursemind.sqlite

# Uploaded course materials are stored under uploads/course-documents by default.
# COURSEMIND_UPLOAD_ROOT=E:/coursemind-data/course-documents

# Defaults to "mock" when unset.
# Supported values today: mock, dify, ragflow.
COURSEMIND_RAG_PROVIDER=mock

# Required only when COURSEMIND_RAG_PROVIDER=dify.
# Example for a local or self-hosted Dify deployment:
# COURSEMIND_DIFY_API_BASE_URL=http://127.0.0.1:5001
# COURSEMIND_DIFY_APP_AUTH=
# COURSEMIND_DIFY_USER_PREFIX=coursemind-demo

# Required only when COURSEMIND_RAG_PROVIDER=ragflow.
# Example for a local or self-hosted RAGFlow deployment:
# COURSEMIND_RAGFLOW_API_BASE_URL=http://127.0.0.1:9380
# COURSEMIND_RAGFLOW_APP_AUTH=
# COURSEMIND_RAGFLOW_CHAT_ID=
# COURSEMIND_RAGFLOW_MODEL=model

# Defaults to "mock" when unset.
# Supported values today: mock, openai-compatible.
COURSEMIND_MODEL_PROVIDER=mock

# Required only when COURSEMIND_MODEL_PROVIDER=openai-compatible.
# This can point to OpenAI-compatible providers such as Qwen, DeepSeek, vLLM, or Ollama.
# COURSEMIND_MODEL_API_BASE_URL=http://127.0.0.1:11434/v1
# COURSEMIND_MODEL_APP_AUTH=
# COURSEMIND_MODEL_NAME=qwen2.5
